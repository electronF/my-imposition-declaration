# ─────────────────────────────────────────────
# AxOvide — Environnement PRODUCTION
# ─────────────────────────────────────────────
# ⚠ Ne jamais commiter ce fichier dans Git
# En production : utiliser les secrets du serveur (vault, env vars système)

ENV=production

# API Claude (Anthropic) — clé production dédiée, rotation régulière
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=claude-opus-4-5

# Serveur
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Base de données SQLite (chemin absolu obligatoire)
DATABASE_URL=sqlite:////var/axovide/data/axovide_prod.db

# Dossier uploads temporaires (nettoyage automatique après extraction)
UPLOAD_DIR=/var/axovide/uploads

# Tailles max fichiers (Mo)
MAX_FILE_SIZE_CV_MB=10
MAX_FILE_SIZE_T4_MB=5
MAX_FILE_SIZE_RL1_MB=5

# CORS — extension Chrome production uniquement
CORS_ORIGINS=chrome-extension://

# Seuil de confiance OCR
CONFIDENCE_THRESHOLD=0.95

# Année fiscale par défaut
DEFAULT_TAX_YEAR=2024

# Logging
LOG_LEVEL=WARNING
