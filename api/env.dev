# ─────────────────────────────────────────────
# AxOvide — Environnement DÉVELOPPEMENT
# ─────────────────────────────────────────────
# ⚠ Ne jamais commiter ce fichier dans Git
# Ajouter .env.* dans .gitignore

ENV=development

# API Claude (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=claude-opus-4-5

# Serveur
HOST=127.0.0.1
PORT=8000
RELOAD=true

# Base de données SQLite
DATABASE_URL=sqlite:///./axovide_dev.db

# Dossier temporaire pour les fichiers uploadés
# Les fichiers sont supprimés après extraction
UPLOAD_DIR=./uploads_dev

# Tailles max fichiers (Mo)
MAX_FILE_SIZE_CV_MB=10
MAX_FILE_SIZE_T4_MB=5
MAX_FILE_SIZE_RL1_MB=5

# CORS — autoriser l'extension Chrome et le dev local
CORS_ORIGINS=chrome-extension://,http://localhost:3000,http://127.0.0.1:3000

# Seuil de confiance OCR (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.95

# Année fiscale par défaut
DEFAULT_TAX_YEAR=2024

# Logging
LOG_LEVEL=DEBUG
